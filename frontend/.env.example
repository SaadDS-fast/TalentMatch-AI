# ==========================================================
# TalentMatch AI Environment Variables
# ==========================================================

# ----------------------------------------------------------
# LLM Provider
# Supported:
#   gemini
#   openai
# ----------------------------------------------------------
DEFAULT_LLM_PROVIDER=gemini


# ----------------------------------------------------------
# OpenAI
# ----------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here


# ----------------------------------------------------------
# Google Gemini
# ----------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here


# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
DEBUG=False


# ----------------------------------------------------------
# Future Database Support
# ----------------------------------------------------------
DATABASE_URL=sqlite:///talentmatch.db